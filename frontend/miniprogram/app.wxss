page {
  background: #f6f7fb;
  color: #1f2430;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 30rpx rgba(31, 36, 48, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.section-desc {
  color: #7a7f8c;
  line-height: 1.7;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: #1f6fff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.ghost-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d9deea;
  background: #ffffff;
  color: #1f2430;
  font-size: 30rpx;
}

.pill {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1f6fff;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.muted {
  color: #7a7f8c;
}

.list-gap {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}