<view class="page list-gap">
  <view class="card" wx:if="{{loading}}">
    <view class="section-title">加载中</view>
    <view class="section-desc">正在获取教练列表...</view>
  </view>

  <view class="card" wx:elif="{{error && list.length === 0}}">
    <view class="section-title">加载失败</view>
    <view class="section-desc">{{error}}</view>
    <button class="ghost-btn" bindtap="resetAndLoad">重新加载</button>
  </view>

  <block wx:else>
    <view class="coach-list">
      <block wx:for="{{list}}" wx:key="id">
        <view class="card coach-item" data-coach-id="{{item.id}}" bindtap="handleCoachTap">
          <view class="coach-avatar">{{item.avatarText}}</view>
          <view class="coach-main">
            <view class="coach-row">
              <view class="coach-name">{{item.name}}</view>
              <text class="pill small-pill">{{item.experience}}</text>
            </view>
            <view class="coach-tags">
              <text class="tag" wx:for="{{item.specialties}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="section-desc coach-intro">{{item.intro}}</view>
          </view>
        </view>
      </block>
    </view>

    <view class="bottom-tip" wx:if="{{loadingMore}}">正在加载更多...</view>
    <view class="bottom-tip muted" wx:elif="{{!hasMore && list.length > 0}}">无更多数据</view>
    <view class="bottom-tip muted" wx:elif="{{list.length === 0}}">暂无教练数据</view>
    <view class="bottom-tip error-tip" wx:elif="{{error}}">{{error}}</view>
  </block>
</view>
