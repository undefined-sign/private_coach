.rating-row {
	margin-bottom: 16rpx;
	display: flex;
	gap: 10rpx;
}

.rating-item {
	padding: 8rpx 14rpx;
	border-radius: 999rpx;
	font-size: 24rpx;
	color: #5d6473;
	background: #f3f5fb;
}

.rating-item.active {
	color: #1f6fff;
	background: #eaf1ff;
	font-weight: 600;
}

.review-input {
	width: 100%;
	min-height: 180rpx;
	padding: 16rpx;
	box-sizing: border-box;
	border-radius: 12rpx;
	background: #f7f9ff;
	font-size: 26rpx;
	margin-bottom: 14rpx;
}

.review-list {
	margin-top: 8rpx;
	display: flex;
	flex-direction: column;
	gap: 16rpx;
}

.review-item {
	padding: 16rpx;
	border-radius: 14rpx;
	background: #f7f9ff;
}

.review-head {
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 12rpx;
	margin-bottom: 10rpx;
}

.review-user {
	font-size: 28rpx;
	font-weight: 600;
	color: #1f2430;
}

.review-stars {
	font-size: 24rpx;
	color: #f7a400;
}

.review-content {
	font-size: 26rpx;
	line-height: 1.6;
	color: #333e55;
}

.review-time {
	margin-top: 8rpx;
	font-size: 22rpx;
	color: #8a91a1;
}

.bottom-tip {
	text-align: center;
	font-size: 24rpx;
	color: #5d6473;
	padding: 12rpx 0 4rpx;
}