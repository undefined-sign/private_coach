<view class="page list-gap">
  <view class="card" wx:if="{{loading}}">
    <view class="section-title">加载中</view>
    <view class="section-desc">正在获取课程评价...</view>
  </view>

  <view class="card" wx:elif="{{error}}">
    <view class="section-title">提示</view>
    <view class="section-desc">{{error}}</view>
    <button class="ghost-btn" bindtap="loadPageData">重试</button>
  </view>

  <block wx:else>
    <view class="card">
      <view class="section-title">{{courseName || '课程评价'}}</view>
      <view class="section-desc" wx:if="{{orderId && canReview}}">订单已完成，可提交评价。</view>
      <view class="section-desc" wx:elif="{{orderId && !canReview}}">当前订单不可评价或已评价。</view>
      <view class="section-desc" wx:else>查看该课程的全部评价。</view>
    </view>

    <view class="card" wx:if="{{orderId && canReview}}">
      <view class="section-title">提交评价</view>
      <view class="rating-row">
        <text
          class="rating-item {{rating >= item ? 'active' : ''}}"
          wx:for="{{[1,2,3,4,5]}}"
          wx:key="*this"
          data-value="{{item}}"
          bindtap="handleRatingTap"
        >{{item}}星</text>
      </view>
      <textarea
        class="review-input"
        maxlength="512"
        placeholder="写下你的真实体验，帮助其他用户做选择..."
        value="{{content}}"
        bindinput="handleContentInput"
      />
      <button class="primary-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleSubmitReview">提交评价</button>
    </view>

    <view class="card">
      <view class="section-title">用户评价</view>
      <view class="section-desc" wx:if="{{!list.length}}">暂无评价，快来成为第一个评价的人。</view>
      <view class="review-list" wx:else>
        <view class="review-item" wx:for="{{list}}" wx:key="id">
          <view class="review-head">
            <view class="review-user">{{item.nickname}}</view>
            <view class="review-stars">{{item.starsText}}</view>
          </view>
          <view class="review-content">{{item.content}}</view>
          <view class="review-time">{{item.createdAtText}}</view>
        </view>
      </view>
      <view class="bottom-tip" wx:if="{{loadingMore}}">正在加载更多...</view>
      <view class="bottom-tip muted" wx:elif="{{!hasMore && list.length > 0}}">没有更多了</view>
    </view>
  </block>
</view>