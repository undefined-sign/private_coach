.section-head {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12rpx;
}

.section-head .section-title {
	margin-bottom: 0;
}

.primary-mini {
	margin: 0;
	padding: 0 22rpx;
	height: 64rpx;
	line-height: 64rpx;
	font-size: 24rpx;
	font-weight: 600;
	color: #ffffff;
	background: #1f6fff;
	border-radius: 999rpx;
	border: 0;
	display: flex;
	align-items: center;
	justify-content: center;
}

.primary-mini::after {
	border: 0;
}

.filter-row,
.form-row {
	margin-top: 14rpx;
	padding: 14rpx 16rpx;
	border-radius: 12rpx;
	background: #f7f9ff;
	border: 1rpx solid #e7eefc;
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12rpx;
}

.filter-label,
.form-label {
	font-size: 25rpx;
	color: #55607a;
}

.picker-value {
	font-size: 26rpx;
	font-weight: 600;
	color: #1f2430;
}

.double-row {
	margin-top: 12rpx;
	display: flex;
	gap: 12rpx;
}

.half-item {
	flex: 1;
	padding: 14rpx 16rpx;
	border-radius: 12rpx;
	background: #f7f9ff;
	border: 1rpx solid #e7eefc;
}

.half-item .form-label {
	margin-bottom: 8rpx;
}

.form-input {
	height: 82rpx;
	line-height: 82rpx;
	margin-top: 12rpx;
	padding: 0 16rpx;
	box-sizing: border-box;
	border-radius: 12rpx;
	background: #f7f9ff;
	border: 1rpx solid #e7eefc;
	font-size: 26rpx;
}

.form-actions {
	display: flex;
	gap: 12rpx;
	margin-top: 16rpx;
}

.form-actions .ghost-btn,
.form-actions .primary-btn {
	flex: 1;
	width: auto;
	display: flex;
	align-items: center;
	justify-content: center;
	text-align: center;
}

.schedule-item {
	display: flex;
	flex-direction: column;
	gap: 8rpx;
}

.schedule-head {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12rpx;
}

.schedule-course {
	font-size: 30rpx;
	font-weight: 700;
	color: #1f2430;
}

.status-pill {
	font-size: 22rpx;
	padding: 6rpx 14rpx;
	border-radius: 999rpx;
	font-weight: 600;
}

.status-available {
	background: #e9f8ef;
	color: #1f8a54;
}

.status-full {
	background: #fff4e8;
	color: #cc7a1c;
}

.status-expired {
	background: #f1f3f7;
	color: #69707c;
}

.status-deleted {
	background: #fbeff1;
	color: #c25566;
}

.item-actions {
	margin-top: 10rpx;
	display: flex;
	gap: 12rpx;
	justify-content: flex-end;
}

.edit-btn {
	margin: 0;
	padding: 0 24rpx;
	height: 70rpx;
	line-height: 70rpx;
	border-radius: 999rpx;
	border: 2rpx solid #cfdaf3;
	background: #f7faff;
	color: #31517f;
	font-size: 24rpx;
	font-weight: 600;
	display: flex;
	align-items: center;
	justify-content: center;
	text-align: center;
}

.edit-btn::after {
	border: 0;
}

.danger-btn {
	margin: 0;
	padding: 0 24rpx;
	height: 70rpx;
	line-height: 70rpx;
	border-radius: 999rpx;
	border: 2rpx solid #f1c9d1;
	background: #fff4f6;
	color: #d55668;
	font-size: 24rpx;
	font-weight: 600;
	display: flex;
	align-items: center;
	justify-content: center;
	text-align: center;
}

.danger-btn::after {
	border: 0;
}

.form-mask {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	background: rgba(20, 28, 45, 0.42);
	z-index: 99;
	display: flex;
	align-items: flex-end;
}

.form-panel {
	width: 100%;
	max-height: 82vh;
	overflow-y: auto;
	background: #ffffff;
	border-radius: 28rpx 28rpx 0 0;
	padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
	box-sizing: border-box;
	box-shadow: 0 -12rpx 32rpx rgba(16, 24, 40, 0.12);
}