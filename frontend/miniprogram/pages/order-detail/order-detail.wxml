<view class="page list-gap">
  <view class="card" wx:if="{{loading}}">
    <view class="section-title">加载中</view>
    <view class="section-desc">正在获取预约详情...</view>
  </view>

  <view class="card" wx:elif="{{error}}">
    <view class="section-title">提示</view>
    <view class="section-desc">{{error}}</view>
    <button class="ghost-btn" bindtap="loadOrderDetail">重试</button>
  </view>

  <block wx:else>
    <view class="card">
      <view class="detail-head">
        <view class="section-title">{{item.courseName}}</view>
        <text class="order-status {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <view class="section-desc">{{item.intro || '暂无课程介绍'}}</view>
    </view>

    <view class="card detail-list">
      <view class="detail-row"><text class="label">预约编号</text><text class="value">{{item.id}}</text></view>
      <view class="detail-row"><text class="label">教练</text><text class="value">{{item.coachName}}</text></view>
      <view class="detail-row" wx:if="{{item.coachContact}}"><text class="label">联系方式</text><text class="value">{{item.coachContact}}</text></view>
      <view class="detail-row"><text class="label">课程类型</text><text class="value">{{item.serviceType}}</text></view>
      <view class="detail-row"><text class="label">课程时长</text><text class="value">{{item.duration}} 分钟</text></view>
      <view class="detail-row"><text class="label">上课日期</text><text class="value">{{item.dateText}}</text></view>
      <view class="detail-row"><text class="label">上课时段</text><text class="value">{{item.timeRange}}</text></view>
      <view class="detail-row"><text class="label">订单金额</text><text class="value amount">{{item.amountText}}</text></view>
    </view>
  </block>
</view>