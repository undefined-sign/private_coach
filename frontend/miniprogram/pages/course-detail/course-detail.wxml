<view class="page">
  <view class="card" wx:if="{{loading}}">
    <view class="section-title">加载中</view>
    <view class="section-desc">正在获取教练课程...</view>
  </view>

  <view class="card" wx:elif="{{error}}">
    <view class="section-title">提示</view>
    <view class="section-desc">{{error}}</view>
    <button class="ghost-btn" bindtap="loadCoachCourses">重试</button>
  </view>

  <block wx:else>
    <view class="card coach-head-card">
      <view class="coach-avatar">{{coach.avatarText}}</view>
      <view class="coach-info">
        <view class="coach-top">
          <view class="section-title coach-title">{{coach.name}} 的课程</view>
          <text class="pill coach-badge">{{coach.experience}}</text>
        </view>
        <view class="section-desc coach-contact" wx:if="{{coach.contact}}">联系方式：{{coach.contact}}</view>
        <view class="coach-tags">
          <text class="tag" wx:for="{{coach.specialties}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="course-list">
      <block wx:for="{{courses}}" wx:key="id">
        <view class="card course-item" data-course-id="{{item.id}}" bindtap="handleCourseTap">
          <view class="course-top">
            <view class="course-name">{{item.name}}</view>
            <text class="level">{{item.level}}</text>
          </view>
          <view class="section-desc course-intro">{{item.intro}}</view>
          <view class="course-actions">
            <view class="course-meta">时长 {{item.duration}} 分钟</view>
            <view class="review-entry" data-course-id="{{item.id}}" catchtap="handleReviewListTap">查看评价</view>
            <view class="course-price">¥{{item.price}}</view>
          </view>
        </view>
      </block>
    </view>
  </block>
</view>