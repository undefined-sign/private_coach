.login-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 44rpx 32rpx 56rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: linear-gradient(180deg, #e9f1ff 0%, #f3f6fc 42%, #f7f8fb 100%);
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(6rpx);
  pointer-events: none;
}

.bg-glow-a {
  width: 420rpx;
  height: 420rpx;
  right: -110rpx;
  top: 80rpx;
  background: radial-gradient(circle, rgba(68, 139, 255, 0.38) 0%, rgba(68, 139, 255, 0) 72%);
}

.bg-glow-b {
  width: 360rpx;
  height: 360rpx;
  left: -120rpx;
  top: 340rpx;
  background: radial-gradient(circle, rgba(47, 206, 171, 0.24) 0%, rgba(47, 206, 171, 0) 72%);
}

.hero-block {
  position: relative;
  z-index: 2;
  width: 100%;
  margin-top: 56rpx;
}

.brand-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  font-weight: 700;
  color: #2e6fda;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(124, 165, 240, 0.55);
  margin-bottom: 18rpx;
}

.login-title {
  font-size: 56rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #1f2b44;
  margin-bottom: 18rpx;
}

.login-desc {
  color: #5b6477;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.benefits-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.benefit-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid #d8e4f8;
  color: #3d4c68;
  font-size: 22rpx;
  font-weight: 600;
}

.login-card {
  position: relative;
  z-index: 2;
  width: 100%;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  padding: 34rpx 30rpx 28rpx;
  box-sizing: border-box;
  border: 1rpx solid #e8eef9;
  box-shadow: 0 16rpx 34rpx rgba(40, 58, 95, 0.1);
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #202b42;
  margin-bottom: 12rpx;
}

.card-desc {
  color: #6c7486;
  font-size: 25rpx;
  margin-bottom: 24rpx;
}

.login-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1f6fff, #3f8dff);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.login-btn::after {
  border: 0;
}

.agreement-text {
  margin-top: 18rpx;
  text-align: center;
  color: #8b92a1;
  font-size: 22rpx;
}