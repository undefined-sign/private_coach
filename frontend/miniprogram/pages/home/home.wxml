<view class="page list-gap">
  <view class="card">
    <view class="section-title">欢迎回来</view>
    <view class="section-desc">{{user ? ('当前登录用户：' + user.nickname + '（ID：' + user.id + '）') : '当前尚未登录，请先完成微信登录。'}}</view>
  </view>

  <view class="card" wx:if="{{loading}}">
    <view class="section-title">加载中</view>
    <view class="section-desc">正在获取教练和课程信息...</view>
  </view>

  <view class="card" wx:elif="{{error}}">
    <view class="section-title">加载失败</view>
    <view class="section-desc">{{error}}</view>
    <button class="ghost-btn" bindtap="loadPageData">重新加载</button>
  </view>

  <block wx:else>
    <view class="card">
      <view class="section-head">
        <view class="section-title">教练展示区</view>
        <view class="section-more" bindtap="handleMoreCoachTap">更多></view>
      </view>
      <view class="coach-list">
        <block wx:for="{{topCoaches}}" wx:key="id">
          <view class="coach-item" data-coach-id="{{item.id}}" bindtap="handleCoachTap">
            <view class="coach-avatar">{{item.avatarText}}</view>
            <view class="coach-main">
              <view class="coach-row">
                <view class="coach-name">{{item.name}}</view>
                <text class="pill small-pill">{{item.experience}}</text>
              </view>
              <view class="coach-tags">
                <text class="tag" wx:for="{{item.specialties}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="card">
      <view class="section-title">课程展示区</view>
      <view class="course-grid">
        <block wx:for="{{courses}}" wx:key="id">
          <view class="course-item" data-course-id="{{item.id}}" bindtap="handleCourseTap">
            <view class="course-head">
              <view class="course-name">{{item.name}}</view>
              <text class="level">{{item.level}}</text>
            </view>
            <view class="section-desc course-intro">{{item.intro}}</view>
            <view class="course-actions">
              <view class="course-meta">时长 {{item.duration}} 分钟</view>
              <view class="course-price">¥{{item.price}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </block>
</view>