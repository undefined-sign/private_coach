.course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-item {
  border: 1rpx solid #e9effb;
  background: linear-gradient(180deg, #ffffff, #fcfdff);
  box-shadow: 0 10rpx 26rpx rgba(31, 49, 86, 0.08);
  padding: 24rpx;
}

.course-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.course-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #1b2438;
  line-height: 1.3;
}

.level {
  font-size: 22rpx;
  color: #2c6de0;
  background: #e8f0ff;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  font-weight: 600;
}

.course-intro {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
  color: #5a6376;
  line-height: 1.65;
}

.course-meta-wrap {
  display: inline-flex;
  max-width: 100%;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f6fd;
  border: 1rpx solid #e5ecfa;
}

.course-meta {
  color: #606a7e;
  font-size: 24rpx;
}

.course-foot {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.course-price {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf0ff;
  color: #1f62dc;
  font-size: 30rpx;
  font-weight: 700;
}

.course-action {
  font-size: 25rpx;
  color: #315fc5;
  font-weight: 600;
}

.bottom-tip {
  text-align: center;
  font-size: 24rpx;
  padding: 18rpx 0 8rpx;
  color: #5d6473;
}

.error-tip {
  color: #d93025;
}
