.schedule-header {
	margin-bottom: 24rpx;
}

.meta-row {
	margin-top: 14rpx;
}

.mock-slot {
	margin: 18rpx 0 20rpx;
	padding: 18rpx;
	border-radius: 14rpx;
	background: #f7f9ff;
	color: #354158;
	font-size: 26rpx;
}

.slot-head {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12rpx;
}

.slot-date {
	font-size: 26rpx;
	font-weight: 600;
	color: #2f3a4f;
}

.slot-time {
	font-size: 30rpx;
	font-weight: 600;
	color: #1f2430;
	flex: 1;
}

.slot-foot {
	margin-top: 10rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 16rpx;
}

.reserve-btn {
	margin: 0;
	padding: 0;
	width: 176rpx;
	height: 50rpx;
	line-height: 50rpx;
	font-size: 23rpx;
	font-weight: 600;
	color: #fff;
	background: linear-gradient(135deg, #2d72f3, #1f6fff);
	border-radius: 999rpx;
	flex-shrink: 0;
}

.reserve-btn::after {
	border: none;
}

.reserve-btn[disabled] {
	opacity: 0.6;
}

.slot-list {
	margin-top: 10rpx;
}

.slot-status {
	padding: 4rpx 12rpx;
	border-radius: 999rpx;
	font-size: 22rpx;
	font-weight: 600;
}

.slot-status.available {
	background: #e8f7ef;
	color: #0b9b57;
}

.slot-status.full {
	background: #f4f5f8;
	color: #7a7f8c;
}

.slot-status.disabled {
	background: #f4f5f8;
	color: #7a7f8c;
}