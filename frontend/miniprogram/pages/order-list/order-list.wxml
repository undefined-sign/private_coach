<view class="page list-gap">
  <view class="card" wx:if="{{loading}}">
    <view class="section-title">加载中</view>
    <view class="section-desc">正在获取你的预约记录...</view>
  </view>

  <view class="card" wx:elif="{{error}}">
    <view class="section-title">提示</view>
    <view class="section-desc">{{error}}</view>
    <button class="ghost-btn" bindtap="loadOrderList">重试</button>
  </view>

  <block wx:else>
    <view class="card tabs-card tabs-sticky">
      <view class="status-tabs">
        <view
          class="tab-item {{activeTab === item.key ? 'tab-item-active' : ''}}"
          wx:for="{{filterTabs}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="handleTabTap"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="card" wx:if="{{!list.length}}">
      <view class="section-title">预约列表</view>
      <view class="section-desc" wx:if="{{activeTab === 'all'}}">你还没有预约记录，去排期页面选择时段预约吧。</view>
      <view class="section-desc" wx:elif="{{activeTab === '0'}}">当前没有“预约中”的记录。</view>
      <view class="section-desc" wx:elif="{{activeTab === '1'}}">当前没有“已取消”的记录。</view>
      <view class="section-desc" wx:else>当前没有“已完成”的记录。</view>
    </view>

    <view class="card order-item" wx:for="{{list}}" wx:key="id" data-order-id="{{item.id}}" bindtap="handleOrderTap">
      <view class="order-head">
        <view class="order-course">{{item.courseName}}</view>
        <text class="order-status {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <view class="order-meta">{{item.slotText}}</view>
      <view class="order-meta">{{item.serviceType}} · {{item.duration}} 分钟 · {{item.coachName}}</view>
      <view class="order-foot">
        <view class="order-amount">{{item.amountText}}</view>
        <view class="order-actions">
          <button
            class="mini-ghost"
            data-order-id="{{item.id}}"
            data-status="{{item.status}}"
            loading="{{cancelingOrderId === item.id}}"
            disabled="{{cancelingOrderId > 0 || item.status !== 0}}"
            catchtap="handleCancelTap"
          >取消</button>
          <button
            class="mini-primary"
            data-order-id="{{item.id}}"
            data-status="{{item.status}}"
            disabled="{{item.status !== 2}}"
            catchtap="handleReviewTap"
          >评价</button>
        </view>
      </view>
    </view>

    <view class="bottom-tip" wx:if="{{loadingMore}}">正在加载更多...</view>
    <view class="bottom-tip muted" wx:elif="{{!hasMore && list.length > 0}}">没有更多了</view>
  </block>
</view>